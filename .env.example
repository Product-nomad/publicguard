# GitHub PAT — needs `public_repo` scope to read repos and `repo` scope to post issues.
# Keep this secret — it's your Product Nomad account's professional identity.
GITHUB_TOKEN=ghp_your_token_here

# Path to the SQLite database file. Defaults to ./data/publicguard.db
# PUBLICGUARD_DB_PATH=./data/publicguard.db

# Set to any value to halt all posting immediately (kill switch).
# Can also be toggled with: publicguard pause / publicguard resume
# PUBLICGUARD_PAUSE=1
